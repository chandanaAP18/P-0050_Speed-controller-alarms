# ---------------- LOGIN ----------------
@app.route("/login", methods=["POST"])
def login():
    u = request.form["username"]
    p = request.form["password"]

    if u in users and users[u]["password"] == p:
        session["user"] = u
        session["role"] = users[u]["role"]
        return redirect("/dashboard")

    return "Invalid Login"

