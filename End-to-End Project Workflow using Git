from flask import Flask, request, redirect, session, jsonify
import numpy as np
from sklearn.linear_model import LinearRegression
import sqlite3
import random

app = Flask(__name__)
app.secret_key = "final_ai_motor_system"

# ---------------- AI MODEL ----------------
voltage = np.array([100,120,140,160,180,200]).reshape(-1,1)
speed = np.array([950,1150,1350,1550,1750,1950])

model = LinearRegression()
model.fit(voltage, speed)

def predict_speed(v):
    return model.predict([[v]])[0]

# ---------------- DATABASE ----------------
def init_db():
    conn = sqlite3.connect("logs.db")
    c = conn.cursor()
    c.execute("CREATE TABLE IF NOT EXISTS logs(speed REAL, status TEXT)")
    conn.commit()
    conn.close()

init_db()

def save_log(speed, status):
    conn = sqlite3.connect("logs.db")
    c = conn.cursor()
    c.execute("INSERT INTO logs VALUES (?,?)", (speed, status))
    conn.commit()
    conn.close()

