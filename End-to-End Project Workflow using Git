# ---------------- LOGS (ADMIN ONLY) ----------------
@app.route("/logs")
def logs():
    if session.get("role") != "admin":
        return "Access Denied"

    conn = sqlite3.connect("logs.db")
    c = conn.cursor()
    data = c.execute("SELECT * FROM logs").fetchall()
    conn.close()

    rows = "".join(f"<tr><td>{s}</td><td>{st}</td></tr>" for s, st in data)

    return f"""
    <html>
    <body>
        <h2>📊 System Logs</h2>
        <table border="1">
            <tr><th>Speed</th><th>Status</th></tr>
            {rows}
        </table>
        <br><a href='/dashboard'>Back</a>
    </body>
    </html>
    """

# ---------------- DATA API ----------------
@app.route("/data")
def data():
    voltage = random.randint(100, 200)
    predicted = predict_speed(voltage)
    actual = predicted + random.randint(-250, 250)

    if actual > predicted + 120:
        status = "🔴 CRITICAL OVER SPEED"
    elif actual < predicted - 120:
        status = "🟡 UNDER SPEED WARNING"
    else:
        status = "🟢 NORMAL"

    save_log(actual, status)

    return jsonify({
        "voltage": voltage,
        "predicted": predicted,
        "actual": actual,
        "status": status
    })

# ---------------- RUN ----------------
if __name__ == "__main__":
    app.run(debug=True)
